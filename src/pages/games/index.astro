---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";
import { brandAccentClass } from "@/data/accentClasses";
---

<BaseLayout title="Free Online Games" description="Play JigSolitaire and more free online browser games, including card games, tile puzzles, word games, logic games, and arcade puzzle favorites.">
  <section class="listing-shell games-hub">
    <header class="listing-header">
      <p class="eyebrow">Game Library</p>
      <h1>Play more browser games.</h1>
      <p>Pick a game, open it in the same clean iframe layout, and keep playing without downloads or accounts.</p>
    </header>
    <div class="site-game-grid">
      <a class:list={["site-game-card", "site-game-card-featured", brandAccentClass]} href="/play/">
        <img src="/level-thumbs/Animals/JigSolitaire_Animals1.webp" alt="JigSolitaire puzzle thumbnail" width="640" height="360" loading="lazy" />
        <div>
          <span>JigSolitaire</span>
          <h2>JigSolitaire Online</h2>
          <p>Swap image tiles, merge correct groups, and restore the full puzzle.</p>
          <small>Featured puzzle game</small>
        </div>
      </a>
      {externalGames.map((game) => (
        <a class:list={["site-game-card", game.accentClass]} href={`/games/${game.slug}/`}>
          <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
          <div>
            <span>{game.category}</span>
            <h2>{game.title}</h2>
            <p>{game.description}</p>
            <small>Play now</small>
          </div>
        </a>
      ))}
    </div>

    <section class="seo-copy-section" aria-labelledby="games-library-guide">
      <div class="section-head">
        <h2 id="games-library-guide">Game library guide.</h2>
      </div>
      <div class="seo-copy-grid">
        <article class="seo-copy-card seo-copy-wide">
          <h3>Free browser games in one place</h3>
          <p>The games library brings together JigSolitaire and a focused set of free online games that work directly in the browser. The goal is to keep every game easy to open, easy to understand, and useful for quick sessions without downloads or account setup. Players can switch from visual tile puzzles to card games, word games, number logic, arcade aiming, or board-clearing puzzles while staying inside the same clean site structure.</p>
        </article>
        <article class="seo-copy-card">
          <h3>How to choose a game</h3>
          <p>Choose JigSolitaire when you want image-based puzzle solving, Solitaire Classic or 4 Color Card Game for card play, Mahjong Connect for tile matching, Word Search for vocabulary focus, Bubble Shooter for quick arcade decisions, Block Puzzle for spatial planning, and Sudoku for pure logic. Each page includes the playable iframe plus supporting tips so visitors understand the rules before they begin.</p>
        </article>
        <article class="seo-copy-card">
          <h3>Why no-download play matters</h3>
          <p>Browser games are useful because they remove friction. You can open a page, play immediately, and leave without installing software. That matters for players on shared computers, mobile devices, school laptops, or work breaks. These pages are built as static Astro routes, which also helps crawlers discover each game page and understand the topic clearly.</p>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>
