---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles } from "@/data/articles";
import { categories } from "@/data/gameData";
import { externalGames } from "@/data/externalGames";
import { siteConfig } from "@/data/siteConfig";
import { brandAccentClass, getCategoryAccentClass } from "@/data/accentClasses";

const recentPosts = articles.slice(0, 3);
const featuredCategories = categories.map((category) => ({
  ...category,
  preview: category.levels[0]?.thumbnail ?? category.levels[0]?.image,
}));
const homeBentoGames = [
  {
    href: "/play/",
    title: "JigSolitaire Online",
    shortTitle: "JigSolitaire",
    category: "Now playing",
    thumbnail: "/level-thumbs/Animals/JigSolitaire_Animals1.webp",
    accent: "#ff5e4d",
    accentClass: brandAccentClass,
  },
  ...externalGames.map((game) => ({
    href: `/games/${game.slug}/`,
    title: game.title,
    shortTitle: game.shortTitle,
    category: game.category,
    thumbnail: game.thumbnail,
    accent: game.accent,
    accentClass: game.accentClass,
  })),
].slice(0, 8);
const homeBentoLeft = homeBentoGames.slice(0, 4);
const homeBentoRight = homeBentoGames.slice(4, 8);

const faqItems = [
  ["What is JigSolitaire?", "JigSolitaire is a free online jigsaw solitaire game where you swap scrambled image tiles until the full picture is restored. Correct adjacent tiles merge into groups as you solve."],
  ["How do you play JigSolitaire online?", "Choose a puzzle, preview the image, then drag tiles to swap positions. Use color, edges, and texture clues to rebuild the picture while correct neighbors merge into larger groups."],
  ["Is JigSolitaire free?", "Yes. JigSolitaire is free to play in the browser with no download, no account, and no app install required."],
  ["Does JigSolitaire work on mobile?", "Yes. JigSolitaire supports mouse and touch play, so it works on desktop, tablets, and modern phones."],
  ["How many JigSolitaire puzzles are included?", `This version includes ${categories.reduce((sum, category) => sum + category.levels.length, 0)}+ levels across Animals, Nature, Cities, Art, and Food collections.`],
];

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    name: "JigSolitaire",
    alternateName: ["JigSolitaire Online", "Jigsaw Solitaire", "jigsolitiare"],
    url: `${siteConfig.siteUrl}/`,
    image: new URL(siteConfig.defaultOgImage, siteConfig.siteUrl).href,
    description: siteConfig.description,
    applicationCategory: "Game",
    gamePlatform: ["Web browser", "Desktop", "Mobile", "Tablet"],
    genre: ["Jigsaw puzzle", "Solitaire puzzle", "Tile swap puzzle"],
    operatingSystem: "Any modern browser",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.publisherName,
      url: siteConfig.siteUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(([question, answer]) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} structuredData={homeStructuredData}>
  <section class="hero-play">
    <div class="home-game-lobby">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Games you can play">
        {homeBentoLeft.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={game.href}>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
      <div class="hero-game">
        <iframe src="/game/index.html" title="Play JigSolitaire" loading="eager"></iframe>
      </div>
      <div class="game-bento-grid game-bento-grid-side" aria-label="More games">
        {homeBentoRight.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={game.href}>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="hero-copy">
      <div class="hero-copy-main">
        <p class="eyebrow">Instant play</p>
        <h1>JigSolitaire Online</h1>
        <p>Play JigSolitaire free in your browser. Swap image tiles, merge correct groups, and restore each jigsaw-style picture with no download and no account.</p>
        <a class="text-link hero-note" href="/how-to-play/">Learn the rules</a>
      </div>
      <div class="hero-play-panel">
        <div class="hero-panel-top">
          <span>Ready in browser</span>
          <strong>Start a visual puzzle.</strong>
        </div>
        <div class="hero-actions">
          <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Full Screen</a>
          <a class="secondary-action" href="/how-to-play/">How To Play</a>
        </div>
        <dl class="stat-row">
          <div><dt>{categories.reduce((sum, category) => sum + category.levels.length, 0)}+</dt><dd>Levels</dd></div>
          <div><dt>{categories.length}</dt><dd>Categories</dd></div>
          <div><dt>{articles.length}</dt><dd>Guides</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="home-section home-search-intent">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">JigSolitaire guide</p>
        <h2>Play the jigsaw solitaire puzzle.</h2>
      </div>
      <p>JigSolitaire combines the calm image solving of a jigsaw puzzle with the quick decisions of a solitaire-style tile board.</p>
    </div>
    <div class="process-strip">
      <article>
        <span>Free</span>
        <h3>Browser play</h3>
        <p>Open <a href="/play/">JigSolitaire online</a> and start a level instantly. The game runs in the browser, so there is no app store, installer, or sign-up flow.</p>
      </article>
      <article>
        <span>Visual</span>
        <h3>Tile swapping</h3>
        <p>Each level begins as a scrambled picture. Move tiles by reading colors, shapes, edge lines, and small landmarks inside the image.</p>
      </article>
      <article>
        <span>Merge</span>
        <h3>Smart progress</h3>
        <p>Correct neighbors merge into movable groups. That makes JigSolitaire feel different from a normal sliding puzzle and keeps each solve readable.</p>
      </article>
      <article>
        <span>Learn</span>
        <h3>Helpful paths</h3>
        <p>Use the <a href="/how-to-play/">how to play guide</a>, browse <a href="/levels/">JigSolitaire levels</a>, or explore <a href="/categories/">puzzle categories</a>.</p>
      </article>
    </div>
  </section>

  <section class="home-section home-worlds">
    <div class="home-section-head">
      <p class="eyebrow">Choose a world</p>
      <h2>Five visual collections.</h2>
      <p>Pick a style, then let color and shape guide the solve.</p>
    </div>
    <div class="world-showcase">
      <a class:list={["world-feature", getCategoryAccentClass(featuredCategories[0].name)]} href="/play/">
        <img src={featuredCategories[0].preview} alt={`${featuredCategories[0].name} JigSolitaire puzzle preview`} width="640" height="360" loading="lazy" />
        <div>
          <span>{featuredCategories[0].name}</span>
          <strong>Begin with Animals.</strong>
          <small>{featuredCategories[0].levels.length} levels ready to play</small>
        </div>
      </a>
      <div class="world-stack">
        {featuredCategories.slice(1).map((category) => (
          <a class:list={["world-card", getCategoryAccentClass(category.name)]} href="/play/">
            <img src={category.preview} alt={`${category.name} JigSolitaire puzzle preview`} width="640" height="360" loading="lazy" />
            <div>
              <span>{category.name}</span>
              <small>{category.levels.length} levels</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section home-process">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">How it works</p>
        <h2>Simple moves. Clear progress.</h2>
      </div>
      <p>Four steps from scrambled image to solved picture.</p>
    </div>
    <div class="process-strip">
      <article><span>01</span><h3>Preview</h3><p>Study the complete image before the tiles scatter.</p></article>
      <article><span>02</span><h3>Swap</h3><p>Drag tiles into stronger positions using color, edges, and texture as clues.</p></article>
      <article><span>03</span><h3>Merge</h3><p>Correct neighbors join into groups, turning progress into momentum.</p></article>
      <article><span>04</span><h3>Finish</h3><p>Restore the image, then chase a cleaner solve or a harder category.</p></article>
    </div>
  </section>

  <section class="home-section home-blog">
    <div class="blog-editorial">
      <div class="home-section-head">
        <p class="eyebrow">From the blog</p>
        <h2>Sharper puzzle thinking.</h2>
        <p>Short reads for better focus, setup, and solving.</p>
        <a class="text-link" href="/blog/">Browse all articles</a>
      </div>
      <div class="blog-board">
        <a class="editorial-card editorial-card-featured" href={`/blog/${recentPosts[0].slug}/`}>
          <span>{recentPosts[0].category}</span>
          <h3>{recentPosts[0].title}</h3>
          <p>{recentPosts[0].description}</p>
          <small>{recentPosts[0].readTime}</small>
        </a>
        <div class="article-rail">
          {recentPosts.slice(1).map((post) => (
            <a class="editorial-card editorial-card-row" href={`/blog/${post.slug}/`}>
              <span>{post.category}</span>
              <h3>{post.title}</h3>
              <small>{post.readTime}</small>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-faq">
    <div class="faq-layout">
      <div class="faq-cardlet">
        <p class="eyebrow">FAQ</p>
        <h2>Quick answers.</h2>
        <p>Need the short version before playing?</p>
      </div>
      <div class="faq-list" data-faq-list>
        {faqItems.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div>
      <p class="eyebrow">Ready?</p>
      <h2>Open a puzzle and start solving.</h2>
    </div>
    <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play JigSolitaire</a>
  </section>

  <script is:inline>
    (() => {
      document.querySelectorAll("[data-faq-list]").forEach((list) => {
        list.querySelectorAll("details").forEach((item) => {
          item.addEventListener("toggle", () => {
            if (!item.open) return;
            list.querySelectorAll("details[open]").forEach((other) => {
              if (other !== item) other.open = false;
            });
          });
        });
      });
    })();
  </script>
</BaseLayout>
