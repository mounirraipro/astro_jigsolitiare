---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategoryAccentClass } from "@/data/accentClasses";
import { categories } from "@/data/gameData";
---

<BaseLayout title="JigSolitaire Categories" description="Browse JigSolitaire puzzle categories including Animals, Nature, Cities, Art, and Food, then play free browser jigsaw solitaire levels online.">
  <section class="listing-shell">
    <header class="listing-header">
      <p class="eyebrow">Puzzle Categories</p>
      <h1>Five imported puzzle worlds.</h1>
      <p>These categories and images come from the original JigSolitaire game assets.</p>
    </header>
    <div class="category-grid">
      {categories.map((category) => (
        <a class:list={["media-card", getCategoryAccentClass(category.name)]} href="/play/">
          <img src={category.levels[0]?.thumbnail ?? category.levels[0]?.image} alt={`${category.name} category preview`} width="640" height="360" loading="lazy" />
          <span>{category.name}</span>
          <small>{category.levels.length} levels</small>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
