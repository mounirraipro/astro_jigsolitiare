---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategoryAccentClass } from "@/data/accentClasses";
import { categories } from "@/data/gameData";

const categoryNames = categories.map((category) => category.name).join(", ");
---

<BaseLayout title="JigSolitaire Categories" description={`Browse JigSolitaire puzzle categories including ${categoryNames}, then play free browser jigsaw solitaire levels online.`}>
  <section class="listing-shell">
    <header class="listing-header">
      <p class="eyebrow">Puzzle Categories</p>
      <h1>{categories.length} puzzle worlds.</h1>
      <p>Browse every visual collection available in the JigSolitaire browser game.</p>
    </header>
    <div class="category-grid">
      {categories.map((category) => (
        <a class:list={["media-card", getCategoryAccentClass(category.name)]} href="/play/">
          <img src={category.levels[0]?.thumbnail ?? category.levels[0]?.image} alt={`${category.name} category preview`} width="640" height="360" loading="lazy" />
          <span>{category.name}</span>
          <small>{category.levels.length} levels</small>
        </a>
      ))}
    </div>

    <section class="seo-copy-section" aria-labelledby="category-guide">
      <div class="section-head">
        <h2 id="category-guide">Category guide.</h2>
      </div>
      <div class="seo-copy-grid">
        <article class="seo-copy-card seo-copy-wide">
          <h3>Choose a JigSolitaire visual theme</h3>
          <p>JigSolitaire categories organize the puzzle library by image style, which makes it easier to choose the right kind of solve. Animals, nature, cities, art, food, space, and fantasy each use the same tile-swap rules, but the visual clues change from clear subjects to dense textures, color fields, architecture, planets, and storybook scenes.</p>
        </article>
        <article class="seo-copy-card">
          <h3>How categories affect difficulty</h3>
          <p>Difficulty is not only about grid size. A simple animal image may be easier than a dense forest scene because the subject has stronger anchors. City puzzles can be approachable when buildings form clear lines, while art and nature puzzles may become harder when colors blend. Use categories to match the kind of pattern recognition you want to practice.</p>
        </article>
        <article class="seo-copy-card">
          <h3>Best way to browse</h3>
          <p>Start with the category that has the clearest image style for you, then move to a harder theme once the swap-and-merge rhythm feels natural. The category pages list individual levels, thumbnails, and difficulty labels, while the play page lets you open the full browser game and continue solving without downloads or account setup.</p>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>
