---
import BlogArticle from "@/components/BlogArticle.astro";
import { articles } from "@/data/articles";

const article = articles.find((item) => item.slug === "how-to-get-better-at-jigsaw-puzzles");
if (!article) throw new Error("Missing article: how-to-get-better-at-jigsaw-puzzles");
---

<BlogArticle article={article} />