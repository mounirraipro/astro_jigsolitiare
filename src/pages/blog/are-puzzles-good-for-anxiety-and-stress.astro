---
import BlogArticle from "@/components/BlogArticle.astro";
import { articles } from "@/data/articles";

const article = articles.find((item) => item.slug === "are-puzzles-good-for-anxiety-and-stress");
if (!article) throw new Error("Missing article: are-puzzles-good-for-anxiety-and-stress");
---

<BlogArticle article={article} />