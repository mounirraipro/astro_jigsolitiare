---
import LevelSpotlightPage from "@/components/LevelSpotlightPage.astro";
import { getCategoryBySlug } from "@/data/gameData";

const category = getCategoryBySlug("animals");
if (!category) throw new Error("Missing animals category");
const level = category.levels[1] ?? category.levels[0];
const related = category.levels.filter((item) => item.id !== level.id).slice(0, 6);
---

<LevelSpotlightPage
  title="Parrot Puzzle Level"
  description="Play a colorful animal-themed JigSolitaire level with bright visual anchors and browser-based puzzle controls."
  heading="Parrot puzzle."
  intro="A brighter animal route built for color matching, edge spotting, and relaxed visual pattern solving."
  category={category}
  level={level}
  related={related}
/>
