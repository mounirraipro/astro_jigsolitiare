---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategoryAccentClass } from "@/data/accentClasses";
import type { GameCategory, GameLevel } from "@/data/gameData";

type Props = {
  title: string;
  description: string;
  heading: string;
  intro: string;
  category: GameCategory;
  level: GameLevel;
  related: GameLevel[];
};

const { title, description, heading, intro, category, level, related } = Astro.props;
const accentClass = getCategoryAccentClass(category.name);
const previewImage = level.thumbnail;
---

<BaseLayout title={title} description={description}>
  <section class="listing-shell level-spotlight">
    <header class="listing-header">
      <p class="eyebrow">{category.name} Level</p>
      <h1>{heading}</h1>
      <p>{intro}</p>
    </header>

    <div class:list={["level-hero-card", accentClass]}>
      <img src={previewImage} alt={`${heading} puzzle preview`} width="1200" height="800" />
      <div>
        <span>{level.gridSize} - {level.difficulty}</span>
        <h2>{level.title}</h2>
        <p>{category.longDescription}</p>
        <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play this puzzle</a>
      </div>
    </div>

    <section class="seo-copy-section" aria-labelledby={`${level.id}-spotlight-guide`}>
      <div class="section-head">
        <h2 id={`${level.id}-spotlight-guide`}>{heading} level notes.</h2>
      </div>
      <div class="seo-copy-grid">
        <article class="seo-copy-card seo-copy-wide">
          <h3>About this {category.name.toLowerCase()} puzzle</h3>
          <p>{heading} is part of the {category.name} JigSolitaire collection, a set of browser puzzles built around visual memory, tile swapping, and progressive group merging. This level uses a {level.gridSize} grid with {level.difficulty.toLowerCase()} pacing, so players can focus on reading the image before making deliberate swaps. It is a useful route for practicing how visual anchors become solved sections.</p>
        </article>
        <article class="seo-copy-card">
          <h3>How to approach it</h3>
          <p>Study the full image during the preview phase and choose two or three anchor details before the shuffle starts. Look for clear edges, high-contrast shapes, or subject features that are easy to recognize inside a single tile. Place those anchors first, then compare neighboring colors and lines until small groups merge and the board becomes easier to manage.</p>
        </article>
        <article class="seo-copy-card">
          <h3>What to practice</h3>
          <p>This level is useful for practicing controlled tile movement rather than guessing. Move pieces into the correct area first, then refine exact placement. If a swap does not create a clearer region, pause and compare the reference image again. Better solves usually come from fewer intentional moves, not from quickly testing every possible tile pair.</p>
        </article>
      </div>
    </section>

    <div class="section-head">
      <h2>More {category.name.toLowerCase()} puzzles after {heading}</h2>
    </div>
    <div class="level-grid">
      {related.map((item) => (
        <a class:list={["level-card", accentClass]} href="/play/">
          <img src={item.thumbnail} alt={`${item.title} puzzle thumbnail`} width="640" height="360" loading="lazy" />
          <strong>{item.title}</strong>
          <span>{item.gridSize} - {item.difficulty}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
