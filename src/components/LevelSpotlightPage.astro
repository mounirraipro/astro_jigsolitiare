---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategoryAccentClass } from "@/data/accentClasses";
import type { GameCategory, GameLevel } from "@/data/gameData";

type Props = {
  title: string;
  description: string;
  heading: string;
  intro: string;
  category: GameCategory;
  level: GameLevel;
  related: GameLevel[];
};

const { title, description, heading, intro, category, level, related } = Astro.props;
const accentClass = getCategoryAccentClass(category.name);
const previewImage = level.image.replace("/levels/", "/levels-webp/").replace(/\.png$/i, ".webp");
---

<BaseLayout title={title} description={description}>
  <section class="listing-shell level-spotlight">
    <header class="listing-header">
      <p class="eyebrow">{category.name} Level</p>
      <h1>{heading}</h1>
      <p>{intro}</p>
    </header>

    <div class:list={["level-hero-card", accentClass]}>
      <img src={previewImage} alt={`${heading} puzzle preview`} width="1200" height="800" />
      <div>
        <span>{level.gridSize} - {level.difficulty}</span>
        <h2>{level.title}</h2>
        <p>{category.longDescription}</p>
        <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play this puzzle</a>
      </div>
    </div>

    <div class="section-head">
      <h2>More animal puzzles.</h2>
    </div>
    <div class="level-grid">
      {related.map((item) => (
        <a class:list={["level-card", accentClass]} href="/play/">
          <img src={item.thumbnail} alt={`${item.title} puzzle thumbnail`} width="640" height="360" loading="lazy" />
          <strong>{item.title}</strong>
          <span>{item.gridSize} - {item.difficulty}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
