---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames, type ExternalGame } from "@/data/externalGames";
import { brandAccentClass } from "@/data/accentClasses";

type Props = {
  game: ExternalGame;
};

const { game } = Astro.props;
const bentoGames = [
  {
    href: `/games/${game.slug}/`,
    title: game.title,
    shortTitle: game.shortTitle,
    category: "Now playing",
    thumbnail: game.thumbnail,
    accent: game.accent,
    accentClass: game.accentClass,
  },
  {
    href: "/play/",
    title: "JigSolitaire Online",
    shortTitle: "JigSolitaire",
    category: "Featured",
    thumbnail: "/level-thumbs/Animals/JigSolitaire_Animals1.webp",
    accent: "#ff5e4d",
    accentClass: brandAccentClass,
  },
  ...externalGames
    .filter((item) => item.slug !== game.slug)
    .map((item) => ({
      href: `/games/${item.slug}/`,
      title: item.title,
      shortTitle: item.shortTitle,
      category: item.category,
      thumbnail: item.thumbnail,
      accent: item.accent,
      accentClass: item.accentClass,
    })),
].slice(0, 8);
const bentoGamesLeft = bentoGames.slice(0, 4);
const bentoGamesRight = bentoGames.slice(4, 8);
---

<BaseLayout title={game.title} description={game.description} seo={{ path: `/games/${game.slug}` }}>
  <section class="embedded-game-page">
    <header class="embedded-game-head">
      <nav class="crumbs"><a href="/games/">Games</a><span>/</span><span>{game.category}</span></nav>
      <h1>{game.title}</h1>
      <p>{game.description}</p>
    </header>

    <div class="embedded-game-layout">
      <div class="game-bento-grid game-bento-grid-side" aria-label="More games">
        {bentoGamesLeft.map((item, index) => (
          <a class:list={["game-bento-card", item.accentClass, { "game-bento-card-featured": index === 0 }]} href={item.href}>
            <img src={item.thumbnail} alt={`${item.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{item.category}</span>
              <strong>{item.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>

      <div class="embedded-game-frame">
        <iframe src={game.iframeUrl} title={game.title} loading="eager" allow="autoplay; fullscreen *" allowfullscreen></iframe>
      </div>

      <div class="game-bento-grid game-bento-grid-side" aria-label="Try next">
        {bentoGamesRight.map((item, index) => (
          <a class:list={["game-bento-card", item.accentClass, { "game-bento-card-featured": index === 0 }]} href={item.href}>
            <img src={item.thumbnail} alt={`${item.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{item.category}</span>
              <strong>{item.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>

    <section class="seo-copy-section embedded-seo-content" aria-labelledby={`${game.slug}-guide`}>
      <div class="section-head">
        <h2 id={`${game.slug}-guide`}>{game.title} guide.</h2>
      </div>
      <div class="seo-copy-grid">
        <article class="seo-copy-card seo-copy-wide">
          <h3>About {game.title}</h3>
          <p>{game.seoOverview}</p>
        </article>
        <article class="seo-copy-card">
          <h3>How to play</h3>
          <p>{game.howToPlay}</p>
        </article>
        <article class="seo-copy-card">
          <h3>Strategy</h3>
          <p>{game.strategyGuide}</p>
        </article>
        <article class="seo-copy-card">
          <h3>Player tips</h3>
          <ul>
            {game.playerTips.map((tip) => <li>{tip}</li>)}
          </ul>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>
