---
import BaseLayout from "@/layouts/BaseLayout.astro";

type Props = {
  title: string;
  path: string;
  description?: string;
};

const { title, path, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="mx-auto w-[min(1080px,calc(100%-48px))] py-12 max-sm:w-[calc(100%-28px)]">
    <p class="mb-6 text-[0.78rem] font-black uppercase tracking-[0.08em] text-game-green after:mt-3.5 after:block after:h-px after:w-10 after:bg-current after:content-['']">Template Route</p>
    <h1 class="mb-5 max-w-[720px] text-[clamp(3.2rem,7.8vw,5.8rem)] font-black leading-[0.92] tracking-normal text-ink max-sm:text-[clamp(2.75rem,18vw,4.2rem)]">{title}</h1>
    <p class="max-w-[720px] text-lg leading-8 text-muted">This route exists for <strong>{path}</strong>. Replace this panel with your game screen, category hub, or level browser when you customize the template.</p>
    <nav class="mt-7 flex flex-wrap gap-3" aria-label="Primary routes">
      <a class="inline-flex min-h-10 items-center rounded-lg border border-line px-3.5 text-sm font-extrabold text-copy no-underline transition hover:border-game-green hover:text-game-green-dark" href="/">Home</a>
      <a class="inline-flex min-h-10 items-center rounded-lg border border-line px-3.5 text-sm font-extrabold text-copy no-underline transition hover:border-game-green hover:text-game-green-dark" href="/play/">Play</a>
      <a class="inline-flex min-h-10 items-center rounded-lg border border-line px-3.5 text-sm font-extrabold text-copy no-underline transition hover:border-game-green hover:text-game-green-dark" href="/how-to-play/">How To Play</a>
      <a class="inline-flex min-h-10 items-center rounded-lg border border-line px-3.5 text-sm font-extrabold text-copy no-underline transition hover:border-game-green hover:text-game-green-dark" href="/blog/">Blog</a>
      <a class="inline-flex min-h-10 items-center rounded-lg border border-line px-3.5 text-sm font-extrabold text-copy no-underline transition hover:border-game-green hover:text-game-green-dark" href="/faq/">FAQ</a>
      <a class="inline-flex min-h-10 items-center rounded-lg border border-line px-3.5 text-sm font-extrabold text-copy no-underline transition hover:border-game-green hover:text-game-green-dark" href="/contact/">Contact</a>
    </nav>
  </section>
</BaseLayout>
